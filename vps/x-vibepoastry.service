[Unit]
Description=x-vibepoastry — X/Twitter API service for local composer
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/x-vibepoastry
ExecStart=/opt/x-vibepoastry/venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8142
Restart=always
RestartSec=5
EnvironmentFile=/opt/x-vibepoastry/.env

[Install]
WantedBy=multi-user.target
